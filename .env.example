# ─────────────────────────────────────────────
#  V-Amber — шаблон переменных окружения
#  Скопируйте этот файл в .env и заполните значения
# ─────────────────────────────────────────────

# ── Yandex SpeechKit (обязательно) ───────────
YANDEX_SPEECHKIT_API_KEY=      # API-ключ из Yandex Cloud IAM
YANDEX_SPEECHKIT_FOLDER_ID=    # ID каталога в Yandex Cloud

# ── YandexGPT (опционально, fallback для артикулов) ───
# Если не указать — используются ключи SpeechKit выше
# YANDEX_GPT_API_KEY=
# YANDEX_GPT_FOLDER_ID=
# YANDEX_GPT_MODEL=yandexgpt-5-lite/latest

# ── VK (опционально) ─────────────────────────
VK_TOKEN=                      # Токен сообщества VK
# VK_LIVE_VIDEO_URL=           # Ссылка на эфир VK — можно не указывать здесь,
                               # вводится прямо в веб-интерфейсе перед стартом
# VK_GROUP_ID=                 # ID группы (если не определяется из VK_LIVE_VIDEO_URL)

# ── Telegram (опционально) ───────────────────
TELEGRAM_BOT_TOKEN=            # Токен бота от @BotFather
TELEGRAM_CHAT_ID=              # ID чата оператора (узнать через @userinfobot)

# ── МойСклад (опционально) ───────────────────
MOYSKLAD_LOGIN=                # Логин МойСклад
MOYSKLAD_PASSWORD=             # Пароль МойСклад
MOYSKLAD_ORGANIZATION_ID=      # UUID организации
MOYSKLAD_STORE_ID=             # UUID склада
# MOYSKLAD_PREFERRED_STORE_NAME=Основной склад
# Склады, исключаемые из суммарного остатка (CSV). По умолчанию: Брак
# MOYSKLAD_EXCLUDED_STORE_NAMES=Брак
# MOYSKLAD_CUSTOMER_ORDER_STATE_ID=   # UUID статуса заказа
# MOYSKLAD_SALES_CHANNEL_ID=          # UUID канала продаж
MOYSKLAD_VK_ID_ATTRIBUTE_ID=          # UUID кастомного атрибута "VK ID" у контрагентов

# ── Настройки сервера ─────────────────────────
PORT=8080

# ── Распознавание артикулов (опционально) ─────
# VOICE_ARTICLE_TRIGGERS=код товара,артикул
# VOICE_ARTICLE_MIN_LENGTH=1
# VOICE_ARTICLE_MAX_LENGTH=10
