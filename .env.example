# ─────────────────────────────────────────────
#  V-Amber — шаблон переменных окружения
#  Скопируйте этот файл в .env и заполните значения
# ─────────────────────────────────────────────

# ── Yandex SpeechKit (обязательно) ───────────
YANDEX_SPEECHKIT_API_KEY=      # API-ключ из Yandex Cloud IAM
YANDEX_SPEECHKIT_FOLDER_ID=    # ID каталога в Yandex Cloud

# ── VK (опционально) ─────────────────────────
VK_TOKEN=                      # Токен сообщества VK
# VK_LIVE_VIDEO_URL=           # Ссылка на эфир VK — можно не указывать здесь,
                               # вводится прямо в веб-интерфейсе перед стартом
# VK_GROUP_ID=                 # ID группы (если не определяется из VK_LIVE_VIDEO_URL)
# VK_API_MIN_INTERVAL_MS=650   # Пауза между запросами к VK API
# VK_API_RATE_LIMIT_BACKOFF_MS=1500 # Backoff при VK API 6

# ── МойСклад (опционально) ───────────────────
MOYSKLAD_LOGIN=                # Логин МойСклад
MOYSKLAD_PASSWORD=             # Пароль МойСклад
MOYSKLAD_ORGANIZATION_ID=      # UUID организации
MOYSKLAD_STORE_ID=             # UUID склада
# MOYSKLAD_PREFERRED_STORE_NAME=Основной склад
# Склады, исключаемые из суммарного остатка (CSV). По умолчанию: Брак
# MOYSKLAD_EXCLUDED_STORE_NAMES=Брак
# Таймаут для bulk-операций МойСклад (загрузка каталога). По умолчанию 60000 мс.
# MOYSKLAD_BULK_REQUEST_TIMEOUT_MS=60000
# MOYSKLAD_CUSTOMER_ORDER_STATE_ID=   # UUID статуса заказа
# MOYSKLAD_SALES_CHANNEL_ID=          # UUID канала продаж
MOYSKLAD_VK_ID_ATTRIBUTE_ID=          # UUID кастомного атрибута "VK ID" у контрагентов

# ── Настройки сервера ─────────────────────────
PORT=8080
# HOST=127.0.0.1                 # Адрес для bind. По умолчанию 0.0.0.0 (нужно для Docker).
                                  # Для локальной установки безопаснее 127.0.0.1.
# API_TOKEN=                      # Если задан — /api/* и WS /ws/stt требуют токен.
                                  # Первый раз открой UI по адресу http://host:PORT/?token=<API_TOKEN>
                                  # — сервер выставит HttpOnly cookie и редиректнёт без токена в URL.
# ALLOWED_ORIGINS=                # CSV-список Origin для WS upgrade (например https://example.com).
                                  # Если не задан — разрешён только loopback (localhost/127.0.0.1).

# ── Собственный стрим MediaMTX (опционально) ──
# Альтернатива VK Live. Без STREAM_MEDIAMTX_API_URL панель "Стрим"
# в дашборде скрыта. См. knowledge/wiki/stream-integration.md.
# STREAM_MEDIAMTX_API_URL=https://<host>/mediamtx  # reverse-proxy на cloud (nginx location /mediamtx/);
                                                   # либо http://127.0.0.1:9997 через SSH-туннель
# STREAM_MEDIAMTX_API_TOKEN=                       # токен прокси (X-Stream-Token); пустой при туннеле
# STREAM_PATH_NAME=live
# STREAM_RTMP_URL=rtmp://<host>:1935              # БЕЗ пути — OBS "Server". Дашборд сам
                                                   # добавляет путь+креды в поле "Ключ" (OBS "Stream Key")
# STREAM_PUBLISH_USER=publisher
# STREAM_PUBLISH_PASS=                            # вместе с USER уходит в поле "ключ публикации"
# STREAM_VIEWER_URL=https://<host>/efir/          # публичная страница зрителя (deploy/stream-viewer/)
# STREAM_STATUS_TIMEOUT_MS=3000
# Дубль эфира в ВК (ffmpeg-релей MediaMTX→ВК). Без VK-цели — выключен.
# Сервер+ключ берутся в ВК: «Трансляции» → настройки OBS. Нужен ffmpeg на маке.
# STREAM_VK_RTMP_URL=rtmp://<vk-ingest-server>/app  # ЛИБО целиком: STREAM_VK_TARGET_URL
# STREAM_VK_KEY=                                   # ключ трансляции ВК (секрет)
# STREAM_RELAY_SOURCE_URL=                         # по умолчанию STREAM_RTMP_URL/<STREAM_PATH_NAME>
# STREAM_FFMPEG_PATH=ffmpeg
# STREAM_RELAY_RESTART_MAX=5
# STREAM_RELAY_RESTART_DELAY_MS=3000
# Чат зрителей на /efir/ (deploy/chat-service на cloud) — второй источник
# броней наравне с VK-комментариями. Без URL поллер чата не запускается.
# STREAM_CHAT_URL=https://<host>/chat
# STREAM_CHAT_TOKEN=                              # секрет операторского фида (OPERATOR_TOKEN чат-сервиса)
# STREAM_CHAT_TIMEOUT_MS=3000
# STREAM_CHAT_POLL_MS=3000
# Кнопка «Запустить эфир» управляет OBS через obs-websocket (OBS 28+):
# в OBS: Сервис → Настройки сервера WebSocket → «Включить сервер».
# OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
# OBS_WEBSOCKET_PASSWORD=                         # пароль из окна настроек WebSocket в OBS
# OBS_TIMEOUT_MS=4000

# ── Распознавание артикулов (опционально) ─────
# VOICE_ARTICLE_TRIGGERS=код товара,артикул
# VOICE_ARTICLE_MIN_LENGTH=1
# VOICE_ARTICLE_MAX_LENGTH=10

# ── YandexGPT fallback (опционально) ──────────
# Вызывается только когда regex ничего не извлёк и каталог МойСклад
# загружен. Любой кандидат от LLM проверяется по каталогу — выдуманный
# артикул не публикуется. Если ключи не заданы, LLM-фаза молча
# пропускается, поведение остаётся как до её добавления.
# YANDEX_GPT_API_KEY=
# YANDEX_GPT_FOLDER_ID=
# YANDEX_GPT_MODEL=yandexgpt-lite/latest
# YANDEX_GPT_ENDPOINT=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
